<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.HistoryDetailFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/topAppBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurface"
                style="@style/Widget.AppCompat.ActionBar.TabBar"
                android:minHeight="?attr/actionBarSize"
                app:navigationContentDescription="@string/back_button_desc"
                app:navigationIcon="@drawable/ic_arrow_left"
                app:title="@string/history_detail_title"
                app:titleCentered="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/image_height"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/resultImageView"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/image_height"
                        android:contentDescription="@string/cd_plant_image"
                        android:scaleType="centerCrop"
                        tools:src="@tools:sample/backgrounds/scenic" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/container_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:accessibilityHeading="true"
                        android:labelFor="@id/plantNameTextView"
                        android:text="@string/label_plant_name_colon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:targetApi="28" />

                    <TextView
                        android:id="@+id/plantNameTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Nama Tanaman" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/content_wrapper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:accessibilityHeading="true"
                        android:text="@string/section_description_title"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        tools:targetApi="28" />

                    <TextView
                        android:id="@+id/contentTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_muted_foreground"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2sp"
                        tools:text="Deskripsi singkat" />

                    <TextView
                        android:id="@+id/benefit_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:accessibilityHeading="true"
                        android:text="@string/section_benefit_title"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        tools:targetApi="28" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/custom_card_green_info"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:id="@+id/benefitTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="0dp"
                            android:textColor="@color/benefit_text"
                            android:textSize="12sp"
                            tools:text="Manfaat" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/warning_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:accessibilityHeading="true"
                        android:text="@string/section_warning_title"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        tools:targetApi="28" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/custom_effect_wrapper"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:id="@+id/warningTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="0dp"
                            android:textColor="@color/warning_text"
                            android:textSize="12sp"
                            tools:text="Peringatan dan Efek Samping" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deleteButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="@string/action_delete"
                        android:textColor="@color/delete_text"
                        app:backgroundTint="@color/delete_bg"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_menu_delete"
                        app:iconGravity="textStart"
                        app:iconTint="@color/delete_icon"
                        app:strokeColor="@color/delete_stroke"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:accessibilityLiveRegion="polite"
        android:contentDescription="@string/loading"
        android:importantForAccessibility="yes"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
