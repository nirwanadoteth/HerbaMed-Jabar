<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.ResultFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/topAppBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurface"
                style="?attr/tabPaddingTop"
                app:navigationContentDescription="@string/back_button_desc"
                app:navigationIcon="@drawable/ic_arrow_left"
                app:title="@string/result_title"
                app:titleCentered="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="19dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="10dp">

                    <ImageView
                        android:id="@+id/resultImageView"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:contentDescription="@string/cd_plant_image"
                        android:scaleType="centerCrop"
                        tools:src="@tools:sample/backgrounds/scenic" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/container_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:accessibilityHeading="true"
                        android:labelFor="@id/plantNameTextView"
                        android:text="@string/label_plant_name_colon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:targetApi="28" />

                    <TextView
                        android:id="@+id/plantNameTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:targetApi="28"
                        tools:text="Nama Tanaman" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/content_wrapper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:accessibilityHeading="true"
                        android:text="@string/section_description_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:targetApi="28" />

                    <TextView
                        android:id="@+id/contentTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:breakStrategy="high_quality"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/text_muted_foreground"
                        android:textSize="12sp"
                        tools:text="Deskripsi singkat" />

                    <TextView
                        android:id="@+id/benefit_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:accessibilityHeading="true"
                        android:text="@string/section_benefit_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:targetApi="28" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/custom_card_green_info"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:id="@+id/benefitTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="0dp"
                            android:textColor="@color/benefit_text"
                            android:textSize="12sp"
                            tools:text="Manfaat" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/warning_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:accessibilityHeading="true"
                        android:text="@string/section_warning_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:targetApi="28" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/custom_effect_wrapper"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:id="@+id/warningTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="0dp"
                            android:textColor="@color/warning_text"
                            android:textSize="12sp"
                            tools:text="Peringatan dan Efek Samping" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/scanAgainButton"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:text="@string/scan_again"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_camera"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_post_to_forum"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="@string/post_to_forum"
                        android:textColor="@color/primary"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_plus"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="@color/primary"
                        app:strokeColor="@color/primary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:accessibilityLiveRegion="polite"
        android:contentDescription="@string/loading"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
